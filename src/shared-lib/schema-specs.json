  "custom_validation_rules": {
    "faqpage_mainentity_is_array_of_questions": {
      "applies_to": "FAQPage",
      "rule": "mainEntity must be an array. Every item must have @type='Question', a non-empty name string, and an acceptedAnswer object with a non-empty text string.",
      "severity_on_fail": "high"
    },
    "faqpage_schema_matches_visible_count": {
      "applies_to": "FAQPage",
      "rule": "The number of Question entities in FAQPage.mainEntity must equal the number of visible FAQ pairs on the page. Mismatch triggers Google's rich-result ineligibility.",
      "severity_on_fail": "high",
      "note": "Requires page HTML inspection — not purely schema-side."
    },
    "breadcrumblist_sequential_positions_from_one": {
      "applies_to": "BreadcrumbList",
      "rule": "itemListElement must be an array of ListItem objects with sequential position values starting from 1 (1, 2, 3, ... n). Gaps or out-of-order positions invalidate the breadcrumb rich result.",
      "severity_on_fail": "medium"
    },
    "every_entity_has_stable_id": {
      "applies_to": "all",
      "rule": "Every JSON-LD entity should carry a stable @id fragment (e.g. https://example.com/#organization). Required for building a coherent entity graph that AI engines can cross-reference across pages.",
      "severity_on_fail": "medium",
      "note": "Not Google-required but high-impact for AEO."
    },
    "datemodified_not_current_timestamp": {
      "applies_to": "Article|BlogPosting|NewsArticle|WebPage",
      "rule": "dateModified must not equal the current timestamp within 60 seconds. A match indicates Date.now()-style cosmetic freshness, which Google's freshness algorithm discounts.",
      "severity_on_fail": "high"
    },
    "datemodified_iso_8601_with_time": {
      "applies_to": "Article|BlogPosting|NewsArticle|WebPage",
      "rule": "dateModified should be full ISO 8601 with time component (e.g. 2026-04-04T00:00:00+00:00), not date-only (2026-04-04). Google accepts both; Schema.org prefers full ISO.",
      "severity_on_fail": "low"
    },
    "person_ymyl_has_credential_or_sameas": {
      "applies_to": "Person",
      "rule": "On YMYL pages (medical, financial, legal, travel-budget), Person entities representing authors/practitioners should carry either hasCredential array OR sameAs links to LinkedIn/professional profiles. Raw 'name + jobTitle' is insufficient for E-E-A-T signals.",
      "severity_on_fail": "high"
    }
  }
